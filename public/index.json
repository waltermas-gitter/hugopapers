te":"2025-02-19T00:00:00Z","relpermalink":"/hugopapers/post/debian/","section":"post","summary":"apt apt purge program-name # elimina config global del programa\napt autoremove # elimina dependencias no utilizadas\nnode curl -fsSL https://deb.nodesource.com/setup_20.x | sudo bash -\nsudo apt-get install -y nodejs\nrepositories directorio /etc/apt/sources.list.d\nsonido alsamixer disable automute\nxcompose en ~/.XCompose:\ninclude \"%L\" # import the default Compose file for your locale #\u003cMulti_key\u003e \u003cbar\u003e \u003cgreater\u003e : \"▸\" #\u003cMulti_key\u003e \u003ca\u003e \u003cb\u003e : \"people\" #\u003ca\u003e \u003cb\u003e : \"sin multikey\" \u003cMulti_key\u003e \u003cMulti_key\u003e \u003ca\u003e : \"ã\" \u003cMulti_key\u003e \u003cMulti_key\u003e \u003co\u003e : \"õ\" \u003cMulti_key\u003e \u003cMulti_key\u003e \u003ce\u003e : \"ê\" en ~/.config/autostart/xmodmap.desktop\n","tags":null,"title":"debian","type":"post"},{"authors":null,"categories":"linux","content":" Xephyr -br -ac -noreset -screen 1680x1050 :1 -fullscreen \u0026amp; DISPLAY=:1 startxfce4 ","date":1736553600,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1736553600,"objectID":"05ceb1b0a948a9b2230892de91543b93","permalink":"http://localhost:1313/hugopapers/post/startx/","publishdate":"2025-01-11T00:00:00Z","relpermalink":"/hugopapers/post/startx/","section":"post","summary":" Xephyr -br -ac -noreset -screen 1680x1050 :1 -fullscreen \u0026 DISPLAY=:1 startxfce4 ","tags":null,"title":"startx","type":"post"},{"authors":null,"categories":"python linux","content":" def registrar_en_archivo(ruta_archivo): def decorador(func): def envoltura(*args, **kargs): resultado = func(*args, **kargs) with open(ruta_archivo, \u0026#34;a\u0026#34;) as archivo: archivo.write(f\u0026#34;llamada a {func.__name__} con argumentos {args} y {kargs}\u0026#34;) return resultado return envoltura return decorador @registrar_en_archivo(\u0026#34;/tmp/registro.txt\u0026#34;) def multiplicar(a, b): return a*b print(multiplicar(3,4)) ","date":1736035200,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1736035200,"objectID":"be9ebbb39f1eb0058d65301966f3781c","permalink":"http://localhost:1313/hugopapers/post/decoradores/","publishdate":"2025-01-05T00:00:00Z","relpermalink":"/hugopapers/post/decoradores/","section":"post","summary":" def registrar_en_archivo(ruta_archivo): def decorador(func): def envoltura(*args, **kargs): resultado = func(*args, **kargs) with open(ruta_archivo, \"a\") as archivo: archivo.write(f\"llamada a {func.__name__} con argumentos {args} y {kargs}\") return resultado return envoltura return decorador @registrar_en_archivo(\"/tmp/registro.txt\") def multiplicar(a, b): return a*b print(multiplicar(3,4)) ","tags":null,"title":"decoradores","type":"post"},{"authors":null,"categories":"linux","content":"tutorial\nyt\nimprime la primer columna ls -l / | awk \u0026#39;{print $1}\u0026#39; cat /etc/passwd | awk -F \u0026#39;:\u0026#39; \u0026#39;{print $1}\u0026#39; $0: todo\n$NF: ultima columna\n-F: delimitador\nusando un archivo ps -ef | awk -f comandos.awk awk -f comandos.awk test1.txt bucle for echo 11 22 33 | awk \u0026#39;{total=0; for(i=0; i\u0026lt;NF; i++) total+=$i; print total}\u0026#39; echo \u0026#34;buenas tardes perri\u0026#34; | awk \u0026#39;{for(i=1;i\u0026lt;=NF;i++) {print $i; system(\u0026#34;sleep 1\u0026#34;)}}\u0026#39; begin, end ls -l / | awk \u0026#39;BEGIN {print \u0026#34;tamaño de los archivos\u0026#34;} {print $9, $5} END{print \u0026#34;chau\u0026#34;}\u0026#39; awk \u0026#39;BEGIN{printf \u0026#34;Col1\\tCol2\\tCol3\\n\u0026#34;} {print $2\u0026#34;\\t\u0026#34;$3\u0026#34;\\t\u0026#34;$7} END{print \u0026#34;Done\u0026#34;}\u0026#39; test1.txt while echo | awk \u0026#39;{i=0; while(i\u0026lt;10){ print i; i++}}\u0026#39; awk \u0026#39;BEGIN{c=0; do {print c; c++} while(c\u0026lt;10)}\u0026#39; variables awk -v var1=xyz \u0026#39;BEGIN{printf \u0026#34;var1 = %s\\n\u0026#34;, var1}\u0026#39; ps -ef | awk \u0026#39;{print NF}\u0026#39; #NF = number of fields(columnas) ps -ef | awk \u0026#39;{print NR}\u0026#39; #NR = record number patterns ps -ef | awk \u0026#39; /tty/ {print}\u0026#39; ps -ef | awk \u0026#39; !/root/ {print}\u0026#39; ps -ef | awk \u0026#39; /root|user/ {print}\u0026#39; ps -ef | awk \u0026#39; /walter/ {c++} END{print \u0026#34;total \u0026#34;, c}\u0026#39; ps -ef | awk \u0026#39;length($0) \u0026lt; 100 {print}\u0026#39; funciones ps -ef | awk \u0026#39;{print length($0)}\u0026#39; ps -ef | awk \u0026#39;{sub(/walter/,\u0026#34;waltermas\u0026#34;); print}\u0026#39; awk \u0026#39;BEGIN{ x=3; if(x*2 == 10) printf \u0026#34;%d matched\u0026#34;, x; else printf \u0026#34;no match\u0026#34;}\u0026#39; awk \u0026#39;BEGIN{a=3; b=6; (a\u0026lt;3)? c=\u0026#34;menor\u0026#34;: c=\u0026#34;mayor\u0026#34;; print c }\u0026#39; awk \u0026#39;function cuadrado(x) {return x*x} BEGIN{ print cuadrado(4)}\u0026#39; awk \u0026#39;BEGIN{a=\u0026#34;hello \u0026#34;; b=\u0026#34;world\u0026#34;; print a b}\u0026#39; #concatenation awk \u0026#39;BEGIN{print rand()}\u0026#39; ","date":1734998400,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1734998400,"objectID":"37986fe93795807a3c50e2b3c6f27358","permalink":"http://localhost:1313/hugopapers/post/awk/","publishdate":"2024-12-24T00:00:00Z","relpermalink":"/hugopapers/post/awk/","section":"post","summary":"tutorial\nyt\nimprime la primer columna ls -l / | awk '{print $1}' cat /etc/passwd | awk -F ':' '{print $1}' $0: todo\n$NF: ultima columna\n-F: delimitador\nusando un archivo ps -ef | awk -f comandos.awk awk -f comandos.awk test1.txt bucle for echo 11 22 33 | awk '{total=0; for(i=0; i\u003cNF; i++) total+=$i; print total}' echo \"buenas tardes perri\" | awk '{for(i=1;i\u003c=NF;i++) {print $i; system(\"sleep 1\")}}' begin, end ls -l / | awk 'BEGIN {print \"tamaño de los archivos\"} {print $9, $5} END{print \"chau\"}' awk 'BEGIN{printf \"Col1\\tCol2\\tCol3\\n\"} {print $2\"\\t\"$3\"\\t\"$7} END{print \"Done\"}' test1.txt while echo | awk '{i=0; while(i\u003c10){ print i; i++}}' awk 'BEGIN{c=0; do {print c; c++} while(c\u003c10)}' variables awk -v var1=xyz 'BEGIN{printf \"var1 = %s\\n\", var1}' ps -ef | awk '{print NF}' #NF = number of fields(columnas) ps -ef | awk '{print NR}' #NR = record number patterns ps -ef | awk ' /tty/ {print}' ps -ef | awk ' !/root/ {print}' ps -ef | awk ' /root|user/ {print}' ps -ef | awk ' /walter/ {c++} END{print \"total \", c}' ps -ef | awk 'length($0) \u003c 100 {print}' funciones ps -ef | awk '{print length($0)}' ps -ef | awk '{sub(/walter/,\"waltermas\"); print}' awk 'BEGIN{ x=3; if(x*2 == 10) printf \"%d matched\", x; else printf \"no match\"}' awk 'BEGIN{a=3; b=6; (a\u003c3)? c=\"menor\": c=\"mayor\"; print c }' awk 'function cuadrado(x) {return x*x} BEGIN{ print cuadrado(4)}' awk 'BEGIN{a=\"hello \"; b=\"world\"; print a b}' #concatenation awk 'BEGIN{print rand()}' ","tags":null,"title":"awk","type":"post"},{"authors":null,"categories":"linux","content":"Como cambiar la carpeta donde guarda las imagenes docker por default.\nsudo nvim /etc/docker/daemon.json\nCrear el archivo si no existe.\n{\n“data-root”: “/run/media/SATURN/docker-images”\n}\nCopiar data:\nsudo rsync -aP /var/lib/docker/ /discos/SDB1/docker\ndocker images\ndocker ps -a\ndocker pull ubuntu:kinetic\ndocker run -t -i ubuntu:latest /bin/bash\ndocker run -t -i [imageid] /bin/bash\n-t terminal\n-i interactive\npress CTRL+P followed by CTRL+Q para salir sin liquidar el container\ndocker run -ti –entrypoint /bin/sh rclone/rclone #cambiando el entrypoint\nparar el container: docker stop parar el container desde dentro: exit\nvolver al container: sudo docker attach rm docker container prune ,para borrar todos los containers detenidos\nborrar una imagen: docker rmi crear una imagen propia, (no parar el container):\ndocker commit 3d24b3de0bfc waltermas/ubuntu_apache\ndocker build -t kine:v0 .\ndocker build -t -f .\ndocker system df -v # espacio que ocupa en disco\nDockerfile FROM debian:12.8 RUN apt update \u0026amp;\u0026amp; apt install -y wget curl neovim zsh git unzip RUN apt install -y libpci3 libegl1 libcubeb0 RUN apt install -y firefox-esr RUN adduser --disabled-password --gecos \u0026#39;\u0026#39; waltermas RUN apt install -y software-properties-common apt-transport-https ca-certificates RUN apt install -y fonts-liberation libvulkan1 xdg-utils WORKDIR /root/sharing RUN curl https://downloads.vivaldi.com/stable/vivaldi-stable_7.0.3495.15-1_amd64.deb -o vivaldi.deb RUN dpkg -i vivaldi.deb CMD [ \u0026#34;/bin/zsh\u0026#34; ] # apt install build-essential # apt install nodejs npm -y # cambiar /root/sharing a /sharing por los permisos docker exec -t con terminal=false en .desktop\nsudo /etc/init.d/dbus\narranca aplicacion sin terminal [Desktop Entry] Version=1.0 Type=Application Name=google-chrome-stable GenericName=google-chrome-stable Comment=google-chrome-stable TryExec=/home/waltermas/scripts/docker/arch/chrome.sh Exec=/home/waltermas/scripts/docker/arch/chrome.sh Terminal=false Icon=google-chrome-stable Categories=Application; StartupWMClass=google-chrome Hidden=false NoDisplay=false StartupNotify=true ","date":1734480000,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1734480000,"objectID":"8b987a11764fa95fae8b94d2e5213018","permalink":"http://localhost:1313/hugopapers/post/docker/","publishdate":"2024-12-18T00:00:00Z","relpermalink":"/hugopapers/post/docker/","section":"post","summary":"Como cambiar la carpeta donde guarda las imagenes docker por default.\nsudo nvim /etc/docker/daemon.json\nCrear el archivo si no existe.\n{\n“data-root”: “/run/media/SATURN/docker-images”\n}\nCopiar data:\nsudo rsync -aP /var/lib/docker/ /discos/SDB1/docker\ndocker images\ndocker ps -a\ndocker pull ubuntu:kinetic\ndocker run -t -i ubuntu:latest /bin/bash\ndocker run -t -i [imageid] /bin/bash\n-t terminal\n-i interactive\npress CTRL+P followed by CTRL+Q para salir sin liquidar el container\ndocker run -ti –entrypoint /bin/sh rclone/rclone #cambiando el entrypoint\n","tags":null,"title":"docker","type":"post"},{"authors":null,"categories":"linux python","content":"argumentos sys.argv[1]\nsublista a partir de lista resultados = [a[’title’] for a in r[‘result’]]\nlist to string busqueda = ’ ‘.join(lista)\nprint(f\u0026#34;la variable es {variable}\u0026#34;)\nvirtualenv python3 -m venv env source env/bin/activate pip install .... which python pip freeze \u0026gt; requirements.txt pip list deactivate pip install -r requirements.txt list comprenhension fruits = [\u0026#34;apple\u0026#34;, \u0026#34;banana\u0026#34;, \u0026#34;cherry\u0026#34;, \u0026#34;kiwi\u0026#34;, \u0026#34;mango\u0026#34;] newlist = [x for x in fruits if \u0026#34;a\u0026#34; in x] print(newlist) ","date":1733702400,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1733702400,"objectID":"d0d836dc25f2e16000312c91c5fe1709","permalink":"http://localhost:1313/hugopapers/post/python/","publishdate":"2024-12-09T00:00:00Z","relpermalink":"/hugopapers/post/python/","section":"post","summary":"argumentos sys.argv[1]\nsublista a partir de lista resultados = [a[’title’] for a in r[‘result’]]\nlist to string busqueda = ’ ‘.join(lista)\nprint(f\"la variable es {variable}\")\nvirtualenv python3 -m venv env source env/bin/activate pip install .... which python pip freeze \u003e requirements.txt pip list deactivate pip install -r requirements.txt list comprenhension fruits = [\"apple\", \"banana\", \"cherry\", \"kiwi\", \"mango\"] newlist = [x for x in fruits if \"a\" in x] print(newlist) ","tags":null,"title":"python","type":"post"},{"authors":null,"categories":"linux","content":"tutorial\nVariables local number = 5 local stringa = \u0026#34;hello, world\u0026#34; local single = \u0026#39;also works\u0026#39; local multi = [[ this is multi line and literal ]] local truth, lies = true, false local nothing = nil MyGlobalVar = \u0026#34;perri\u0026#34; functions local function hello(name) print(\u0026#34;hello\u0026#34;, name) return \u0026#34;ok\u0026#34; -- pueden tener varios returns end local greet = function(name) print(\u0026#34;Greetings, \u0026#34; .. name .. \u0026#34;!\u0026#34;) end local M = {} M.alpha = function(...) -- todos los parametros print(\u0026#34;hola\u0026#34;, ...) end M.alpha(\u0026#34;hola\u0026#34;, \u0026#34;youtube\u0026#34;, 2) tables --lists local list = {\u0026#34;first\u0026#34;, 2, false, function() print(\u0026#34;Fourth\u0026#34;) end } print(\u0026#34;yup, 1-indexed\u0026#34;, list[1]) table.insert(list, \u0026#34;alpha\u0026#34;) table.insert(list, 2, \u0026#34;alpha\u0026#34;) table.remove(list, 3) --maps local t = { literal_key = \u0026#34;a string\u0026#34;, [\u0026#34;an expression\u0026#34;] = \u0026#34;also works\u0026#34;, } print(\u0026#34;literal key :\u0026#34;, t.literal_key) for local favoritos = { \u0026#34;teej\u0026#34;, \u0026#34;the primagen\u0026#34;, \u0026#34;terminaldoshop\u0026#34;} for index = 1, #favoritos do print(index, favoritos[index]) end for index, value in ipairs(favoritos) do print(index, value) end local scores = { teej = 9.5, theprimagen = \u0026#34;dd\u0026#34;} for key, value in pairs(scores) do print(key, value) end if if condicion then print(\u0026#34;true\u0026#34;) else print(\u0026#34;false\u0026#34;) end -- toma como false: nil, false. Todo lo demas es true and -- and or -- or ~= -- es diferente modules -- foo.lua local M = {} M.cool_function = function() end return M -- bar.lua local foo = require(\u0026#39;foo\u0026#39;) foo.cool_function() lua para vim tutorial :source %\n:messages\nvim.notify(\u0026#34;hola perri\u0026#34;) print(vim.inspect(variable)) -- para ver el contenido de una tabla vim.tbl_... -- funciones para tablas os -- para funciones del sistema (bloqueante) vim.system -- para funciones del sistema (no bloqueante) vim.system(vim.split(\u0026#34;ls -la\u0026#34;, \u0026#34; \u0026#34;), {}, function(out) print(\u0026#34;output:\u0026#34;, out.stdout) end) strings local name = \u0026#34;alpha\u0026#34; name::gsub(\u0026#34;al\u0026#34;, \u0026#34;xx\u0026#34;) es igual a string.gsub(name, \u0026#34;al\u0026#34;, \u0026#34;xx\u0026#34;) local res = string.format(\u0026#34;hola %s\u0026#34;, name) print (\u0026#34;hola \u0026#34; .. name) user commands tutorial\nvim.api.nvim_create_user_command(\u0026#39;Prueba\u0026#39;, function() vim.notify(\u0026#39;Creating prueba.txt with a greeting\u0026#39;, vim.log.levels.INFO, { title = \u0026#39;Prueba Command\u0026#39; }) end, { desc = \u0026#39;Notify test\u0026#39; } ) :Prueba -- con argumentos vim.api.nvim_create_user_command(\u0026#39;Argumento\u0026#39;, function(args) vim.print(vim.inspect(args.fargs[1])) end, { desc = \u0026#39;Notify test\u0026#39;, nargs=1, complete= function () return {\u0026#34;alpha\u0026#34;, \u0026#34;beta\u0026#34;} end } ) -- autocommands local group = vim.api.nvim_create_augroup(\u0026#34;MyAutoCommands\u0026#34;, { clear = true }) vim.api.nvim_create_autocmd(\u0026#34;Colorscheme\u0026#34;, { group = group, callback = function() vim.notify(\u0026#34;Colorscheme changed to: \u0026#34; .. vim.g.colors_name) end, }) ","date":1733356800,"expirydate":-62135596800,"kind":"page","lang":"en","lastmod":1733356800,"objectID":"c3c5dd58edf9800648afb186d7d7b428","permalink":"http://localhost:1313/hugopapers/post/lua/","publishdate":"2024-12-05T00:00:00Z","relpermalink":"/hugopapers/post/lua/","section":"post","summary":"tutorial\nVariables local number = 5 local stringa = \"hello, world\" local single = 'also works' local multi = [[ this is multi line and literal ]] local truth, lies = true, false local nothing = nil MyGlobalVar = \"perri\" functions local function hello(name) print(\"hello\", name) return \"ok\" -- pueden tener varios returns end local greet = function(name) print(\"Greetings, \" .. name .. \"!\") end local M = {} M.alpha = function(...) -- todos los parametros print(\"hola\", ...) end M.alpha(\"hola\", \"youtube\", 2) tables --lists local list = {\"first\", 2, false, function() print(\"Fourth\") end } print(\"yup, 1-indexed\", list[1]) table.insert(list, \"alpha\") table.insert(list, 2, \"alpha\") table.remove(list, 3) --maps local t = { literal_key = \"a string\", [\"an expression\"] = \"also works\", } print(\"literal key :\", t.literal_key) for local favoritos = { \"teej\", \"the primagen\", \"terminaldoshop\"} for index = 1, #favoritos do print(index, favoritos[index]) end for index, value in ipairs(favoritos) do print(index, value) end local scores = { teej = 9.5, theprimagen = \"dd\"} for key, value in pairs(scores) do print(key, value) end if if condicion then print(\"true\") else print(\"false\") end -- toma como false: nil, false. Todo lo demas es true and -- and or -- or ~= -- es diferente modules -- foo.lua local M = {} M.cool_function = function() end return M -- bar.lua local foo = require('foo') foo.cool_function() lua para vim tutorial :source %\n:messages\n","tags":null,"title":"lua","type":"post"},{"authors":null,"categories":"linux","content":"w3school\nlas tres maneras file \u0026lt;head\u0026gt; \u0026lt;link rel=\u0026#34;stylesheet\u0026#34; href=\u0026#34;mystyle.css\u0026#34;\u0026gt; \u0026lt;/head\u0026gt; en el head \u0026lt;head\u0026gt; \u0026lt;style\u0026gt; body { background-color: linen; } h1 { color: maroon; margin-left: 40px; } \u0026lt;/style\u0026gt; \u0026lt;/head\u0026gt; inline \u0026lt;p style=\u0026#34;color:red;\u0026#34;\u0026gt;This is a paragraph.\u0026lt;/p\u0026gt; /* id=\u0026#34;para1\u0026#34; */ #para1 { text-align: center; color: red; } /* class=\u0026#34;center\u0026#34; */ .center { text-align: center; color: red; } /* \u0026lt;p class=\u0026#34;center\u0026#34;\u0026gt;\u0026lt;/p\u0026gt; */ p.center { text-align: center; color: red; } /* \u0026lt;p class=\u0026#34;center large\u0026#34;\u0026gt;para los selectores center y los de large\u0026lt;/p\u0026gt; */ h1, h2, p { text-align: center; color: red; } ","date":1732924800,"expirydate":-62135596800,"kind":"page","lang"